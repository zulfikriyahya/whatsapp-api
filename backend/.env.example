# ─────────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
TZ=Asia/Jakarta
CLIENT_URL=http://localhost:3001
COOKIE_SECRET=ganti_dengan_openssl_rand_hex_32
COOKIE_SECURE=false
COOKIE_DOMAIN=localhost
ADMIN_EMAIL=admin@yourdomain.com
STORAGE_PATH=./storage
MAX_FILE_SIZE_MB=50
DEFAULT_DAILY_MESSAGE_LIMIT=1000
DEFAULT_MONTHLY_BROADCAST_LIMIT=10
LOG_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=90
BACKUP_PATH=./storage/backups

# ─────────────────────────────────────────────────────────────
# DATABASE (MySQL)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=mysql://root:password@localhost:3306/whatsapp_gateway

# ─────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=wgw:

# ─────────────────────────────────────────────────────────────
# JWT
# Generate: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────
JWT_SECRET=ganti_dengan_openssl_rand_hex_32
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────
# GOOGLE OAUTH
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ─────────────────────────────────────────────────────────────
# GEMINI AI
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy_your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_MS=10000
GEMINI_CONFIDENCE_THRESHOLD=0.6

# ─────────────────────────────────────────────────────────────
# WHATSAPP (whatsapp-web.js)
# ─────────────────────────────────────────────────────────────
WA_AUTH_PATH=./storage/sessions
WA_HEADLESS=true
WA_MAX_RECONNECT_RETRIES=10
WARMING_INTERVAL_MIN_MS=300000
WARMING_INTERVAL_MAX_MS=600000

# ─────────────────────────────────────────────────────────────
# THROTTLE / RATE LIMIT
# ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_AUTH_LIMIT=10
THROTTLE_API_KEY_LIMIT=300

# ─────────────────────────────────────────────────────────────
# BULLMQ — Broadcast & Webhook Queue
# ─────────────────────────────────────────────────────────────
BROADCAST_CONCURRENCY=1
BROADCAST_RATE_MAX=10
BROADCAST_RATE_DURATION_MS=1000
WEBHOOK_CONCURRENCY=5
WEBHOOK_MAX_RETRIES=5

# ─────────────────────────────────────────────────────────────
# CLEANUP CRON
# ─────────────────────────────────────────────────────────────
CLEANUP_CRON=0 2 * * *

# ─────────────────────────────────────────────────────────────
# SMTP EMAIL
# Kosongkan SMTP_HOST jika tidak ingin menggunakan fitur email.
# Untuk Gmail: aktifkan 2FA lalu buat App Password di
# https://myaccount.google.com/apppasswords
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=noreply@yourdomain.com

# ─────────────────────────────────────────────────────────────
# GLOBAL IP WHITELIST (opsional)
# Kosongkan untuk mengizinkan semua IP
# ─────────────────────────────────────────────────────────────
# GLOBAL_IP_WHITELIST=127.0.0.1,192.168.1.0/24
