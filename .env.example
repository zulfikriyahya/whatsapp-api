# ── APP ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
TZ=Asia/Jakarta

# ── DATABASE ─────────────────────────────────────────────────
DATABASE_URL="mysql://root:PASSWORD@localhost:3306/whatsapp_gateway"

# ── REDIS ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=wgw:

# ── JWT ──────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── GOOGLE OAUTH ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ── ADMIN ────────────────────────────────────────────────────
ADMIN_EMAIL=

# ── COOKIE ───────────────────────────────────────────────────
# Generate: openssl rand -hex 32
COOKIE_SECRET=
COOKIE_SECURE=false
COOKIE_DOMAIN=localhost

# ── CORS ─────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3001

# ── GEMINI AI ────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=10000
GEMINI_CONFIDENCE_THRESHOLD=0.6

# ── WHATSAPP ─────────────────────────────────────────────────
WA_AUTH_PATH=./storage/sessions
WA_HEADLESS=true
WA_MAX_RECONNECT_RETRIES=10

# ── STORAGE ──────────────────────────────────────────────────
STORAGE_PATH=./storage
MAX_FILE_SIZE_MB=50

# ── RATE LIMITING ────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_AUTH_LIMIT=10
THROTTLE_API_KEY_LIMIT=300

# ── BULLMQ ───────────────────────────────────────────────────
BROADCAST_CONCURRENCY=1
BROADCAST_RATE_MAX=10
BROADCAST_RATE_DURATION_MS=1000
WEBHOOK_CONCURRENCY=5
WEBHOOK_MAX_RETRIES=5

# ── CLEANUP ──────────────────────────────────────────────────
CLEANUP_CRON=0 2 * * *
LOG_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=90

# ── WARMING ──────────────────────────────────────────────────
WARMING_INTERVAL_MIN_MS=300000
WARMING_INTERVAL_MAX_MS=600000

# ── QUOTA DEFAULT ────────────────────────────────────────────
DEFAULT_DAILY_MESSAGE_LIMIT=1000
DEFAULT_MONTHLY_BROADCAST_LIMIT=10

# ── GLOBAL IP WHITELIST (opsional) ───────────────────────────
# GLOBAL_IP_WHITELIST=127.0.0.1,192.168.1.0/24
